programa {
  funcao inicio() {
    cadeia peca1, peca2

  escreva("Quantas peças o setor A produziu?: ")
  leia(peca1)


    escreva("Quantas peças o setor B produziu?: ")
    leia(peca2)


se (peca1 > peca2)
escreva("Setor A produziu mais")

    
    senao
    escreva("Setor B produziu mais")









  }
}
